DATABASE_URL=postgresql://postgres:password@localhost:5432/sepm_crop_db
FRONTEND_ORIGIN=http://localhost:5173

# Optional: https://data.gov.in/ — without this key, live prices only work if your
# local scraper runs at http://127.0.0.1:5000/request (see agmarknet_client.py).
# If you see 403 "Key not authorised": the key is wrong OR not enabled for this dataset.
# Log in → open the exact dataset/API page → use “Request API” / enable access if required → copy key with no spaces.
AGMARKNET_API_KEY=your_data_gov_in_api_key_here
# AGMARKNET_BASE_URL defaults to the Daily Price resource JSON endpoint; override only if needed.
