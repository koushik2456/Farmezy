# Copy to backend/.env and fill values (backend/.env is gitignored).
# Settings load from this path automatically — you can run uvicorn from any cwd.

# --- Database ---
# Local Postgres (same machine as the API):
DATABASE_URL=postgresql://postgres:password@localhost:5432/sepm_crop_db
# Quick local dev without Postgres:
# DATABASE_URL=sqlite:///./sepm_crop_db.db

# --- CORS ---
# Vite dev server URL. The API also allows 127.0.0.1:5173 automatically so either host works in the browser.
FRONTEND_ORIGIN=http://localhost:5173

# --- data.gov.in (Agmarknet daily prices) ---
# https://data.gov.in/ — create an account → My account → API key. Enable access for this dataset if required.
# The backend sends the key as Authorization: Bearer <key> and as api-key query param (portal may require Bearer).
AGMARKNET_API_KEY=your_data_gov_in_api_key_here
# Default is the Daily Price API resource; override only if you use another dataset.
AGMARKNET_BASE_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
# Optional: when running the seeder, set to 1 to also pull unfiltered pages (many commodities per request).
# AGMARKNET_BULK_SEED=1
# AGMARKNET_BULK_PAGES=2
